# Copia este archivo como .env y rellena los valores reales

# Base de datos PostgreSQL (Neon, Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clave secreta para JWT (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia_esto_por_una_clave_segura

# Configuración JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
